# Where the Quill backend is running.
#   Local dev:  http://localhost:8787
#   Deployed:   your Railway backend URL (e.g. https://quill-backend-production.up.railway.app)
QUILL_API_URL=http://localhost:8787
# The agent key from the Quill UI (Settings → Your agent). Required whenever the
# backend has an owner password / API_KEY set — always true for a deployed instance.
QUILL_API_KEY=

# ─── Local development ──────────────────────────────────────────────
# On Railway, set these as service Variables instead (see the Railway notes
# at the bottom). The production start command reads process.env directly, so
# no .env file is needed there. Never commit real secrets — .env is gitignored.

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jarvx_backend"
APP_BASE_URL="http://localhost:4310"     # REQUIRED, valid URL — the frontend origin (used as the CORS origin)
API_BASE_URL="http://localhost:8787"     # REQUIRED, valid URL — this backend's public URL
JWT_SECRET="replace-with-a-long-random-string"          # must be >= 32 chars
ENCRYPTION_KEY_BASE64="replace-with-32-byte-base64-key"  # must be >= 32 chars
DEFAULT_USER_EMAIL="owner@example.com"
DEFAULT_USER_NAME="Owner"

X_CLIENT_ID=""
X_CLIENT_SECRET=""
X_CALLBACK_URL="http://localhost:8787/api/x/callback"   # = <backend public URL>/api/x/callback
X_SCOPES="tweet.read users.read tweet.write media.write offline.access"

ANALYTICS_ENABLED="false"
ANALYTICS_WINDOW_DAYS="7"
ANALYTICS_RETENTION_DAYS="14"
ANALYTICS_MAX_POSTS="500"
ANALYTICS_REFRESH_LAST_24H_HOURS="3"
ANALYTICS_REFRESH_DAYS_2_TO_7_HOURS="12"

MONTHLY_OWNED_READ_BUDGET="10000"
DAILY_OWNED_READ_SOFT_LIMIT="300"
DAILY_OWNED_READ_HARD_LIMIT="500"

AI_PROVIDER="none"
AI_API_KEY=""

# Set to require Bearer auth on /api (recommended once deployed). Empty = open (local dev).
API_KEY=""

# ─── Railway (production) ───────────────────────────────────────────
# Set these in the backend service's Variables tab (values, not this file):
#   DATABASE_URL          = ${{Postgres.DATABASE_URL}}   (reference to the Postgres plugin)
#   APP_BASE_URL          = https://<frontend-public-domain>
#   API_BASE_URL          = https://<backend-public-domain>
#   X_CALLBACK_URL        = https://<backend-public-domain>/api/x/callback
#   JWT_SECRET            = openssl rand -hex 32
#   ENCRYPTION_KEY_BASE64 = openssl rand -base64 32
#   API_KEY               = <optional bearer key>
# X_CLIENT_ID/SECRET are optional — Quill's in-app setup UI stores them encrypted in the DB.
# NOTE: schema.prisma uses only env("DATABASE_URL"). Do NOT enable Railway's PgBouncer
# pooling unless you also add directUrl to schema.prisma — `prisma migrate deploy` breaks
# through a transaction pooler. Plain Postgres works out of the box.

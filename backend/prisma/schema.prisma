generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// SQLite has no native enums; these String fields hold the union values
// defined in src/lib/db-enums.ts (ScheduledPostStatus, PostType,
// AutomationStatus, AssistantRole, XOperationType).

model User {
  id                       String    @id @default(uuid())
  email                    String    @unique
  name                     String?
  passwordHash             String?
  agentApiKeyEncrypted     String?
  agentApiKeyHash          String?   @unique
  timezone                 String    @default("UTC")
  themeAccent              String    @default("#009ef8")
  assistantCollapsed       Boolean   @default(false)
  analyticsEnabled         Boolean   @default(false)
  analyticsWindowDays      Int       @default(7)
  analyticsRetentionDays   Int       @default(14)
  monthlyOwnedReadBudget   Int       @default(10000)
  dailyOwnedReadSoftLimit  Int       @default(300)
  dailyOwnedReadHardLimit  Int       @default(500)
  writingProfile           Json?
  replyProfile             Json?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  xAccount                 XAccount?
  oauthStates              OAuthState[]
  writingExamples          SavedWritingExample[]
  researchItems            ResearchItem[]
  researchRules            ResearchRule[]
  extensionInstallations   ExtensionInstallation[]
}

model OAuthState {
  id           String    @id @default(uuid())
  userId       String
  state        String    @unique
  codeVerifier String
  redirectAfter String?
  expiresAt    DateTime
  consumedAt   DateTime?
  createdAt    DateTime  @default(now())

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

model XAccount {
  id                    String   @id @default(uuid())
  userId                String   @unique
  xUserId               String   @unique
  username              String
  displayName           String?
  avatarUrl             String?
  accessTokenEncrypted  String
  refreshTokenEncrypted String?
  scopes                Json     @default("[]")
  writeEnabled          Boolean  @default(false)
  lastSyncedAt          DateTime?
  analyticsLastSyncedAt DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user                  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts                 Post[]
  scheduledPosts        ScheduledPost[]
  mediaAssets           MediaAsset[]
  ctaSetting            CtaSetting?
  ctaAutomations        CtaAutomation[]
  repostRules           AutoRepostRule[]
  assistantChats        AssistantChat[]
  usageEvents           XApiUsageEvent[]
}

model Post {
  id                  String   @id @default(uuid())
  xAccountId          String
  xPostId             String
  text                String
  createdAtX          DateTime
  postType            String
  conversationId      String?
  inReplyToUserId     String?
  referencedTweets    Json?
  attachments         Json?
  entities            Json?
  publicMetrics       Json?
  organicMetrics      Json?
  nonPublicMetrics    Json?
  views               Int?
  likes               Int?
  reposts             Int?
  replies             Int?
  bookmarks           Int?
  engagementRate      Float?
  lastMetricsSyncedAt DateTime?
  rawX                Json?
  expiresAt           DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  xAccount            XAccount @relation(fields: [xAccountId], references: [id], onDelete: Cascade)

  @@unique([xAccountId, xPostId])
  @@index([xAccountId, createdAtX])
  @@index([xAccountId, expiresAt])
}

model ScheduledPost {
  id              String              @id @default(uuid())
  xAccountId      String
  status          String              @default("SCHEDULED")
  text            String?
  threadParts     Json?
  quotePostId     String?
  replyToPostId   String?
  media           Json?
  ctaConfig       Json?
  scheduledAt     DateTime
  timezone        String
  idempotencyKey  String              @unique
  postedXPostId   String?
  errorCode       String?
  errorMessage    String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  xAccount        XAccount            @relation(fields: [xAccountId], references: [id], onDelete: Cascade)
  researchDraft   ResearchDraft?

  @@index([status, scheduledAt])
}

// Files a person owns and explicitly uploads to Quill for a future post. They
// are retained on Quill's durable volume until they are either deleted or used
// by a scheduled post; X media IDs are intentionally not stored here because
// those uploads expire.
model MediaAsset {
  id          String   @id @default(uuid())
  xAccountId  String
  storageKey  String   @unique
  filename    String
  contentType String
  bytes       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  xAccount    XAccount @relation(fields: [xAccountId], references: [id], onDelete: Cascade)

  @@index([xAccountId, createdAt])
}

model CtaSetting {
  id          String   @id @default(uuid())
  xAccountId  String   @unique
  text        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  xAccount    XAccount @relation(fields: [xAccountId], references: [id], onDelete: Cascade)
}

model CtaAutomation {
  id              String           @id @default(uuid())
  xAccountId      String
  sourceXPostId   String
  ctaText         String
  likeThreshold   Int              @default(50)
  status          String           @default("PENDING")
  replyXPostId    String?
  lastCheckedAt   DateTime?
  expiresAt       DateTime
  postedAt        DateTime?
  idempotencyKey  String           @unique
  errorMessage    String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  xAccount        XAccount         @relation(fields: [xAccountId], references: [id], onDelete: Cascade)

  @@index([status, lastCheckedAt])
  @@index([xAccountId, sourceXPostId])
}

model AutoRepostRule {
  id                  String           @id @default(uuid())
  xAccountId          String
  sourceXPostId       String
  sourceUrl           String
  status              String           @default("ACTIVE")
  cadenceHours        Int
  nextRunAt           DateTime
  lastRunAt           DateTime?
  lastRepostXPostId   String?
  idempotencySeed     String           @unique
  errorMessage        String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  xAccount            XAccount         @relation(fields: [xAccountId], references: [id], onDelete: Cascade)

  @@index([status, nextRunAt])
}

model AssistantChat {
  id          String   @id @default(uuid())
  xAccountId  String
  title       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  xAccount    XAccount           @relation(fields: [xAccountId], references: [id], onDelete: Cascade)
  messages    AssistantMessage[]
}

model AssistantMessage {
  id                String        @id @default(uuid())
  chatId            String
  role              String
  content           String
  structuredActions Json?
  createdAt         DateTime      @default(now())

  chat              AssistantChat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId, createdAt])
}

model SavedWritingExample {
  id        String   @id @default(uuid())
  userId    String
  label     String?
  text      String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Public posts, threads, profiles, and articles deliberately live outside
// Post. Post is reserved for the connected account's own X history; mixing
// the two would corrupt voice learning and analytics.
model ResearchItem {
  id              String   @id @default(uuid())
  userId          String
  type            String   @default("POST")
  url             String
  xPostId         String?
  sourceHandle    String?
  authorName      String?
  title           String?
  text            String   @default("")
  raw             Json?
  matchedKeywords Json     @default("[]")
  status          String   @default("NEW")
  importance      Int      @default(0)
  reason          String?
  capturedAt      DateTime @default(now())
  openedAt        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  researchDraft   ResearchDraft?
  generatedReply  ResearchReply?

  @@unique([userId, url])
  @@index([userId, status, importance])
  @@index([userId, capturedAt])
}

model ResearchRule {
  id        String   @id @default(uuid())
  userId    String
  kind      String
  value     String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, kind, value])
  @@index([userId, kind, enabled])
}

// Browser companions receive a separate token rather than the person's agent
// key. These tokens are revocable and accepted only by research endpoints.
model ExtensionInstallation {
  id         String    @id @default(uuid())
  userId     String
  tokenHash  String    @unique
  label      String    @default("Quill browser companion")
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
}

// A reply proposal remains a normal ScheduledPost draft. This link lets the
// browser companion show the proposal beside the captured opportunity.
model ResearchDraft {
  id              String        @id @default(uuid())
  researchItemId  String        @unique
  scheduledPostId String        @unique
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  researchItem    ResearchItem  @relation(fields: [researchItemId], references: [id], onDelete: Cascade)
  scheduledPost   ScheduledPost @relation(fields: [scheduledPostId], references: [id], onDelete: Cascade)
}

// Prepared by Quill's backend model and safe for the browser companion to
// display/copy. This is not a ScheduledPost and cannot publish by itself.
model ResearchReply {
  id             String       @id @default(uuid())
  researchItemId String       @unique
  text           String
  status         String       @default("READY")
  provider       String
  model          String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  researchItem   ResearchItem @relation(fields: [researchItemId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
}

model XApiUsageEvent {
  id                    String         @id @default(uuid())
  xAccountId            String?
  endpoint              String
  method                String
  operationType         String
  requestCount          Int            @default(1)
  resourcesReturned     Int            @default(0)
  ownedResourcesCharged Int            @default(0)
  estimatedCostUsd      Float          @default(0)
  statusCode            Int?
  rateLimitLimit        Int?
  rateLimitRemaining    Int?
  rateLimitReset        DateTime?
  createdAt             DateTime       @default(now())

  xAccount              XAccount?      @relation(fields: [xAccountId], references: [id], onDelete: SetNull)

  @@index([xAccountId, createdAt])
  @@index([operationType, createdAt])
}

model OutboxEvent {
  id          String   @id @default(uuid())
  type        String
  payload     Json
  availableAt DateTime @default(now())
  attempts    Int      @default(0)
  lastError   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type, availableAt])
}

// Single-row legacy configuration retained only to migrate older installs. New
// passwords and agent keys live on User; shared X app credentials stay here.
// Secrets are encrypted with ENCRYPTION_KEY_BASE64, like the X tokens.
model AppConfig {
  id                     String   @id @default("singleton")
  legacyPasswordHash     String?  @map("ownerPasswordHash")
  xClientIdEncrypted     String?
  xClientSecretEncrypted String?
  agentApiKeyEncrypted   String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

{
  "name": "quill-backend",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Quill API — composer, scheduling, CTA, repost, assistant, and X integration.",
  "scripts": {
    "dev": "node --watch --env-file=.env --import tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:local": "node --env-file=.env dist/server.js",
    "postinstall": "prisma generate",
    "test": "node --import tsx --test \"tests/**/*.test.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "worker": "node --env-file=.env --import tsx src/workers/index.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^12.0.1",
    "@fastify/jwt": "^9.0.2",
    "@prisma/client": "^6.1.0",
    "fastify": "^5.2.0",
    "nanoid": "^5.0.9",
    "prisma": "^6.1.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}

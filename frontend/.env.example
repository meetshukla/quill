# Base URL of the Quill backend (Fastify). No trailing slash.
#
# IMPORTANT: NEXT_PUBLIC_* is INLINED AT BUILD TIME by `next build`. On Railway
# this variable MUST be set on the frontend service BEFORE the build runs, and
# changing it later requires a REBUILD (not just a restart) to take effect.
#   Railway value: NEXT_PUBLIC_API_BASE_URL = https://<backend-public-domain>
NEXT_PUBLIC_API_BASE_URL=http://localhost:8787
